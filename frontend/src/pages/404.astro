---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer'
---

<Layout title="404" description="Page not found">
  <main class="container">
    <Nav />
    <div class="not-found">
      <p class="not-found-code">404</p>
      <h1 class="not-found-heading">page not found</h1>
      <p class="not-found-sub">this path doesn't exist. might have moved, might never have existed.</p>
      <a href="/" class="not-found-link">← back to home</a>
    </div>
    <Footer client:load />
  </main>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 6rem 0;
  }

  .not-found-code {
    font-size: 80px;
    font-weight: 300;
    color: var(--accent);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 1rem;
    opacity: 0.4;
  }

  .not-found-heading {
    font-size: 28px;
    font-weight: 300;
    color: #f2f4f8;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .not-found-sub {
    font-size: 13px;
    color: #8b9ab0;
    font-weight: 300;
    line-height: 1.85;
    max-width: 400px;
    margin-bottom: 2rem;
  }

  .not-found-link {
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: opacity 0.15s;
  }

  .not-found-link:hover {
    opacity: 0.7;
  }
</style>
