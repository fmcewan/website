---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer'
import '../styles/about.css'
---

<Layout title="About">
  <main class="container">
    <Nav />

    <div class="profile-row">
      <div class="profile-left">
        <img src="/avatar.jpg" alt="Fraser McEwan" class="profile-photo" />
        <span class="profile-name">Fraser McEwan</span>
        <span class="profile-title">software engineer</span>
      </div>
      <div class="profile-middle">
        <p class="section-label">profile</p>
        <p class="bio">
          I'm a Computer Science and Mathematics graduate from the University of Manchester.
          I build software in C++, Python and TypeScript with a focus on correctness,
          performance and systems that are built to last. 
        </p>
      </div>
    </div>

    <section class="section">
      <p class="section-label">education</p>
      <div class="rows">
        <div class="row">
          <div class="row-main">
            <span class="row-title">BSc (Hons) Computer Science and Mathematics</span>
            <span class="row-sub">University of Manchester</span>
          </div>
          <div class="row-right">
            <span class="tag">2:1 — 66.2%</span>
            <span class="date">2021 – 2025</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <p class="section-label">stack</p>
      <div class="rows">
        <div class="row">
          <div class="row-left">
            <i class="devicon-typescript-plain colored"></i>
            <span class="row-name">TypeScript</span>
          </div>
          <span class="tag">language</span>
        </div>
        <div class="row">
          <div class="row-left">
            <i class="devicon-python-plain colored"></i>
            <span class="row-name">Python</span>
          </div>
          <span class="tag">language</span>
        </div>
        <div class="row">
          <div class="row-left">
            <i class="devicon-c-plain colored"></i>
            <span class="row-name">C</span>
          </div>
          <span class="tag">language</span>
        </div>
        <div class="row">
          <div class="row-left">
            <i class="devicon-cplusplus-plain colored"></i>
            <span class="row-name">C++</span>
          </div>
          <span class="tag">language</span>
        </div>
        <div class="row">
          <div class="row-left">
            <i class="devicon-react-original colored"></i>
            <span class="row-name">React</span>
          </div>
          <span class="tag">frontend</span>
        </div>
        <div class="row">
          <div class="row-left">
            <i class="devicon-astro-plain colored"></i>
            <span class="row-name">Astro</span>
          </div>
          <span class="tag">framework</span>
        </div>
        <div class="row">
          <div class="row-left">
            <i class="devicon-nodejs-plain colored"></i>
            <span class="row-name">Node.js</span>
          </div>
          <span class="tag">runtime</span>
        </div>
        <div class="row">
          <div class="row-left">
            <i class="devicon-postgresql-plain colored"></i>
            <span class="row-name">PostgreSQL</span>
          </div>
          <span class="tag">database</span>
        </div>
      </div>
    </section>

    <section class="section">
      <p class="section-label">software</p>
      <div class="rows">
        <div class="row">
          <div class="row-left">
            <i class="devicon-neovim-plain colored"></i>
            <span class="row-name">Neovim</span>
          </div>
          <span class="detail">editor</span>
        </div>
        <div class="row">
          <div class="row-left">
            <i class="ti ti-terminal"></i>
            <span class="row-name">Ghostty</span>
          </div>
          <span class="detail">terminal</span>
        </div>
        <div class="row">
          <div class="row-left">
            <i class="ti ti-palette" style="color: #78a9ff;"></i>
            <span class="row-name">Carbonfox</span>
          </div>
          <span class="detail">theme</span>
        </div>
      </div>
    </section>

    <Footer client:load />
  </main>
</Layout>
