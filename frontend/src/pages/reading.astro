---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav'
import Footer from '../components/Footer'
import '../styles/reading.css'

const completed = [
  { title: 'Meditations', author: 'Marcus Aurelius', isbn: '9780140449334' },
]

const reading = [
  { title: 'The Pragmatic Programmer', author: 'Andy Hunt & Dave Thomas', isbn: '9780135957059' },
  { title: 'Flowers for Algernon', author: 'Daniel Keyes', isbn: '9780156030304' },
]

const upNext = [
  { title: 'A Philosophy of Software Design', author: 'John Ousterhout', isbn: '9781732102200' },
  { title: "Computer Systems: A Programmer's Perspective", author: "Bryant & O'Hallaron", isbn: '9780134092669' },
  { title: 'Zen and the Art of Motorcycle Maintenance', author: 'Robert M. Pirsig', isbn: '9780060839871' },
  { title: 'The Myth of Sisyphus', author: 'Albert Camus', isbn: '9780679733966' },
  { title: "Surely You're Joking, Mr. Feynman!", author: 'Richard Feynman', isbn: '9780393316049' },
  { title: 'Blood Meridian', author: 'Cormac McCarthy', isbn: '9780679728757' },
]
---

<Layout title="Reads">
  <main class="container">
    <Nav client:load />

    <section class="section">
      <p class="section-label">completed</p>
      <div class="rows">
        {completed.map((book) => (
          <div class="row">
            <img
              src={`https://covers.openlibrary.org/b/isbn/${book.isbn}-M.jpg`}
              alt={book.title}
              class="book-cover"
              loading="lazy"
            />
            <span class="dot dot-completed"></span>
            <div>
              <span class="book-title">{book.title}</span>
              <span class="book-author">{book.author}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <section class="section">
      <p class="section-label">reading</p>
      <div class="rows">
        {reading.map((book) => (
          <div class="row">
            <img
              src={`https://covers.openlibrary.org/b/isbn/${book.isbn}-M.jpg`}
              alt={book.title}
              class="book-cover"
              loading="lazy"
            />
            <span class="dot dot-reading"></span>
            <div>
              <span class="book-title">{book.title}</span>
              <span class="book-author">{book.author}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <section class="section">
      <p class="section-label">up next</p>
      <div class="rows">
        {upNext.map((book) => (
          <div class="row">
            <img
              src={`https://covers.openlibrary.org/b/isbn/${book.isbn}-M.jpg`}
              alt={book.title}
              class="book-cover"
              loading="lazy"
            />
            <span class="dot dot-upnext"></span>
            <div>
              <span class="book-title">{book.title}</span>
              <span class="book-author">{book.author}</span>
            </div>
          </div>
        ))}
      </div>
    </section>    
    <Footer client:load />
  </main>
</Layout>
