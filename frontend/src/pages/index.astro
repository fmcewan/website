---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer'
import HeroGraph from '../components/HeroGraph'

import { getCollection } from 'astro:content'

const posts = await getCollection('blog', ({ data }) => !data.draft)
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
const recentPosts = posts.slice(0, 3)

const projects = await getCollection('projects')
projects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<Layout title="Home">
  <main class="container">
    <Nav/>

    <section class="hero">
      <div class="hero-content">

        <p class="hero-label">FRASER MCEWAN</p>

        <h1 class="hero-name">I'm a<br /><span>software engineer.</span></h1>
        <p class="hero-bio">
          I write software that's clean, considered, and built to last.
          I'm drawn to difficult problems and the craft of software engineering done well.
          See my <a href="/projects" class="bio-link">projects</a> or read <a href="/about" class="bio-link">about me</a>.
        </p>
        <div class="hero-links">
          <a href="https://github.com/fmcewan" target="_blank" class="hero-link">
            <i class="ti ti-brand-github" aria-hidden="true"></i> GitHub 
          </a>
          <a href="https://linkedin.com/in/fraser-mcewan-517186253/" target="_blank" class="hero-link">
            <i class="ti ti-brand-linkedin" aria-hidden="true"></i> LinkedIn 
          </a>
        </div>
      </div>
      <div class="hero-graph">
        <HeroGraph client:load />
      </div>
    </section>

    <div class="cta-block">
      <div class="cta-status">
        <span class="cta-dot"></span>
        open to work
      </div>
      <h2 class="cta-heading">I'm looking for a <span>graduate role</span><br/>in software engineering.</h2>
      <p class="cta-sub">
      </p>
      <div class="cta-actions">
        <a href="/cv.pdf" target="_blank" class="cta-primary">Download my CV →</a>
        <a href="mailto:frasermcewan6@gmail.com" class="cta-secondary">Get in touch →</a>
      </div>
    </div>

    <div class="divider"></div>
    
    <section class="section">
      <p class="section-label">selected projects</p>
      <div class="projects">
        {projects.map((project) => (
          <a href={`/projects/${project.id}`} class="project">
            <div class="project-left">
              <span class="project-name">{project.data.title}</span>
              <span class="project-desc">{project.data.description}</span>
            </div>
            <div class="project-right">
              {project.data.tags.slice(0, 1).map((tag) => (
                <span class="project-tag">{tag}</span>
              ))}
              <span class="project-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <p class="section-label">recent notes</p>
      <div class="posts">
        {recentPosts.map((post) => (
          <a href={`/log/${post.id}`} class="post">
            <span class="post-title">{post.data.title}</span>
            <span class="post-date">
              {post.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
            </span>
          </a>
        ))}
      </div>
    </section>

    <Footer client:load />
  </main>
</Layout>

<style>
    @import '../styles/index.css';
</style>
