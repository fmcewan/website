---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer'
import { getCollection } from 'astro:content'
import '../../styles/log.css'

const posts = await getCollection('blog', ({ data }) => !data.draft)
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const reading = [
  { title: 'The Pragmatic Programmer', author: 'Andy Hunt & Dave Thomas', isbn: '9780135957059' },
  { title: 'Flowers for Algernon', author: 'Daniel Keyes', isbn: '9780156030304' },
]

const upNext = [
  { title: 'A Philosophy of Software Design', author: 'John Ousterhout', isbn: '9781732102200' },
  { title: "Computer Systems: A Programmer's Perspective", author: "Bryant & O'Hallaron", isbn: '9780134092669' },
  { title: 'Zen and the Art of Motorcycle Maintenance', author: 'Robert M. Pirsig', isbn: '9780060839871' },
  { title: 'The Myth of Sisyphus', author: 'Albert Camus', isbn: '9780679733966' },
  { title: "Surely You're Joking, Mr. Feynman!", author: 'Richard Feynman', isbn: '9780393316049' },
  { title: 'Blood Meridian', author: 'Cormac McCarthy', isbn: '9780679728757' },
]
---

<Layout title="Log">
  <main class="container">
    <Nav />

    <section class="section">
      <p class="section-label">notes</p>
      <p class="log-intro">Thoughts on software and whatever else is on my mind.</p>
      <div class="posts">
        {posts.map((post) => (
          <a href={`/log/${post.id}`} class="post">
            <span class="post-title">{post.data.title}</span>
            <span class="post-date">
              {post.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
            </span>
          </a>
        ))}
      </div>
    </section>


    <section class="section">
      <p class="section-label">reading</p>

      <p class="reading-sub">currently reading</p>
      <div class="rows" style="margin-bottom: 2rem;">
        {reading.map((book) => (
          <div class="row">
            <img src={`https://covers.openlibrary.org/b/isbn/${book.isbn}-M.jpg`} alt={book.title} class="book-cover" loading="lazy" />
            <span class="dot dot-reading"></span>
            <div>
              <span class="book-title">{book.title}</span>
              <span class="book-author">{book.author}</span>
            </div>
          </div>
        ))}
      </div>

      <p class="reading-sub">up next</p>
      <div class="rows">
        {upNext.map((book) => (
          <div class="row">
            <img src={`https://covers.openlibrary.org/b/isbn/${book.isbn}-M.jpg`} alt={book.title} class="book-cover" loading="lazy" />
            <span class="dot dot-upnext"></span>
            <div>
              <span class="book-title">{book.title}</span>
              <span class="book-author">{book.author}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <Footer client:load />
  </main>
</Layout>
