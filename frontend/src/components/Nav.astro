---
const path = Astro.url.pathname
---

<nav class="nav" id="site-nav">
  <a href="/" class={path === '/' ? 'logo active' : 'logo'}>fmcewan.dev</a>

  <ul class="links">
    <li><a href="/projects" class={path.startsWith('/projects') ? 'link-accent active' : 'link-accent'}>projects</a></li>
    <li><a href="/about" class={path === '/about' ? 'link active' : 'link'}>about</a></li>
    <li><a href="/now" class={path === '/now' ? 'link active' : 'link'}>now</a></li>
    <li><a href="/log" class={path.startsWith('/log') ? 'link active' : 'link'}>log</a></li>
  </ul>

  <button class="hamburger" id="hamburger" aria-label="Toggle menu">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>

  <div class="mobile-menu" id="mobile-menu">
    <a href="/projects" class={path.startsWith('/projects') ? 'mobile-link active' : 'mobile-link'}>projects</a>
    <a href="/about" class={path === '/about' ? 'mobile-link active' : 'mobile-link'}>about</a>
    <a href="/now" class={path === '/now' ? 'mobile-link active' : 'mobile-link'}>now</a>
    <a href="/log" class={path.startsWith('/log') ? 'mobile-link active' : 'mobile-link'}>log</a>
  </div>
</nav>

<style>
  /* ── Layout ── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 0;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    transition: all 0.2s ease;
  }

  /* Frosted glass background on scroll */
  .nav::before {
    content: '';
    position: absolute;
    top: 0;
    left: -2.5rem;
    right: -2.5rem;
    bottom: 0;
    background: rgba(10, 15, 20, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 0.5px solid rgba(255, 255, 255, 0.08);
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: -1;
  }

  .nav.scrolled::before {
    opacity: 1;
  }

  /* ── Logo ── */
  .logo {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #f2f4f8;
    text-decoration: none;
  }

  .logo.active { color: #78a9ff; }

  /* ── Desktop links ── */
  .links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .link {
    font-size: 12px;
    color: #8b9ab0;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: color 0.15s;
  }

  .link:hover,
  .link.active { color: #f2f4f8; }

  .link-accent {
    font-size: 13px;
    font-weight: 500;
    color: #f2f4f8;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: color 0.15s;
  }

  .link-accent:hover,
  .link-accent.active { color: #78a9ff; }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .bar {
    display: block;
    width: 20px;
    height: 1px;
    background: #8b9ab0;
    transition: all 0.2s;
  }

  .hamburger.open .bar:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .hamburger.open .bar:nth-child(2) { opacity: 0; }
  .hamburger.open .bar:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* ── Mobile menu ── */
  .mobile-menu {
    display: none;
    flex-direction: column;
    width: 100%;
    border-top: 0.5px solid rgba(255, 255, 255, 0.08);
    margin-top: 1rem;
  }

  .mobile-menu.open { display: flex; }

  .mobile-link {
    display: block;
    padding: 0.9rem 0;
    font-size: 13px;
    color: #8b9ab0;
    text-decoration: none;
    letter-spacing: 0.06em;
    border-bottom: 0.5px solid rgba(255, 255, 255, 0.05);
    transition: color 0.15s;
  }

  .mobile-link:hover,
  .mobile-link.active { color: #78a9ff; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .links { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  const nav = document.querySelector('nav')
  const hamburger = document.getElementById('hamburger')
  const menu = document.getElementById('mobile-menu')

  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 10)
  })

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('open')
    menu?.classList.toggle('open')
  })
</script>
