---
---

<nav class="nav">
  <a href="/" class="logo">fmcewan.dev</a>

  <ul class="links">
    <li><a href="/projects" class="link-accent">projects</a></li>
    <li><a href="/about" class="link">about</a></li>
    <li><a href="/notes" class="link">notes</a></li>
    <li><a href="/reading" class="link">reading</a></li>
  </ul>

  <button class="hamburger" id="hamburger" aria-label="Toggle menu">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>

  <div class="mobile-menu" id="mobile-menu">
    <a href="/projects" class="mobile-link">projects</a>
    <a href="/about" class="mobile-link">about</a>
    <a href="/notes" class="mobile-link">notes</a>
    <a href="/reading" class="mobile-link">reading</a>
  </div>
</nav>

<style>
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 5rem;
    position: relative;
    flex-wrap: wrap;
  }

  .logo {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #f2f4f8;
    text-decoration: none;
  }

  .links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .link {
    font-size: 12px;
    color: #8b9ab0;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: color 0.15s;
  }

  .link:hover { color: #78a9ff; }

  .link-accent {
    font-size: 13px;
    font-weight: 500;
    color: #f2f4f8;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: color 0.15s;
  }

  .link-accent:hover { color: #78a9ff; }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .bar {
    display: block;
    width: 20px;
    height: 1px;
    background: #8b9ab0;
    transition: all 0.2s;
  }

  .hamburger.open .bar:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .hamburger.open .bar:nth-child(2) { opacity: 0; }
  .hamburger.open .bar:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    flex-direction: column;
    width: 100%;
    border-top: 0.5px solid rgba(255, 255, 255, 0.08);
    margin-top: 1rem;
  }

  .mobile-menu.open { display: flex; }

  .mobile-link {
    display: block;
    padding: 0.9rem 0;
    font-size: 13px;
    color: #8b9ab0;
    text-decoration: none;
    letter-spacing: 0.06em;
    border-bottom: 0.5px solid rgba(255, 255, 255, 0.05);
    transition: color 0.15s;
  }

  .mobile-link:hover { color: #78a9ff; }

  @media (max-width: 768px) {
    .links { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger')
  const menu = document.getElementById('mobile-menu')

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('open')
    menu?.classList.toggle('open')
  })
</script>
